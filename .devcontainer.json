{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cpptools-themes"
      ],
      "settings": {
        "files.eol": "\n",
        "C_Cpp.default.compilerPath": "/bin/cpp",
        "C_Cpp.default.includePath": [
          "${workspaceFolder}/**",
          "/nginx/src/**",
          "/nginx/objs/**"
        ]
      }
    }
  },
  "forwardPorts": [8888]
}
