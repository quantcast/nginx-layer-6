shopt -s nullglob
headers=(*.h)
sources=(*.c)
shopt -u nullglob # Turn off nullglob to make sure it doesn't interfere with anything later
echo "Found headers: ${headers[@]}" 
echo "Found sources: ${sources[@]}" 

rm ./config
cp ./conf/config-template ./config

echo "\nNGX_ADDON_DEPS=\"\$NGX_ADDON_DEPS \\" >> ./config
for header in ${headers[@]}
do
    echo "\t\$ngx_addon_dir/$header \\" >> ./config
done
echo "\"" >> ./config

echo "NGX_ADDON_SRCS=\"\$NGX_ADDON_SRCS \\" >> ./config
for source in ${sources[@]}
do
    echo "\t\$ngx_addon_dir/$source \\" >> ./config
done
echo "\"" >> ./config

echo "Generated new nginx module config!"
