# Simple script to make an HTTP request using curl with predefined data
PORT=
HOST=
TEST_FILE=
DATA=

while [[ $# -gt 0 ]]; do
    case $1 in
        -p|--port)
            shift
            PORT=$1
            shift
            ;;
        -h|--host)
            shift
            HOST=$1
            shift
            ;;
        -f|--file)
            shift
            TEST_FILE=$1
            shift
            ;;
        -d|--data)
            shift
            DATA=$1
            shift
            ;;
        -h|--help)
            echo 'Usage: ./make-request [-p] [-h] [-fd]'
            echo "    --port (-p) - The port to send the request to"
            echo "    --host (-h) - The host address to hit with a request"
            echo "    --file (-f) - The test file to use as the body of the request"
            echo "    --data (-d) - The data to use as the body of the request (defaults to data if both -d and -f are provided)"
            echo "NOTE: To make a GET request, do not provide a -f or -d argument"
            shift
            exit 0
            ;;
        -*|--*)
            echo "Unknown option $1"
            echo 'Usage: ./make-request [options]'
            echo "    --port (-p) - The port to send the request to"
            echo "    --host (-h) - The host address to hit with a request"
            echo "    --file (-f) - The test file to use as the body of the request"
            exit 1
            ;;
    esac
done

if [ -z $PORT ] || [ -z $HOST ]
then
    echo "Illegal usage: must have flags [-p] [-h]"
    exit 1
fi

# detect whether to use $DATA or $TEST_FILE
if [ -z $DATA ] && [ -z $TEST_FILE ]
then
    echo "Calling curl on address $HOST:$PORT with no data (GET)"
    curl "$HOST:$PORT"
elif [ -z $TEST_FILE ]
then
    echo "Calling curl on address $HOST:$PORT with given data (POST)"
    curl "$HOST:$PORT" -d "$DATA"
else
    echo "Calling curl on address $HOST:$PORT with data from $TEST_FILE (POST)"
    curl "$HOST:$PORT" -d "$(cat $TEST_FILE)"
fi
